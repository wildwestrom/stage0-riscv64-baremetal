    # ADDI T0, S1, 0 ; grab jump_table
    93820400

:backend_GetTarget_loop_0
    # ADDIW T1, X0, 513 ; scratch
    1B031020
    # SLLI T1, T1, 0X16 ; scratch
    13136301
    # LD T2, 16(T0) ; I->name
    83B30201

