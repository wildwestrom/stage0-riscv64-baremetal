    # JAL RA, BACKEND_GETTARGET ; Get target
    $backend_GetTarget EF000000
    # LD A1, 0(A0) ; Dereference pointer
    83350500
    # SUB A1, A2, A1 ; displacement = target - ip
    B305B640
    # JAL X0, BACKEND_STOREPOINTER_0 ; Continue looping
