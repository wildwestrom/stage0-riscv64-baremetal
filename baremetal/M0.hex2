    # ADDI A0, X0, 0 ; a0 = 0
    13050000
    # JAL RA, BACKEND_WRITE_BYTE ; write 0
    $backend_write_byte EF000000

:backend_PadToAlign_1
    # ADDI T1, X0, 2 ; t1 = 2
    13032000
    # AND A0, S6, T1 ; ip & 0x2
    33756B00
    # BNE A0, T1, BACKEND_PADTOALIGN_2 ; check if ip & 0x2 == 2
