    # ADDI A0, X0, 0 ; a0 = 0
    13050000
    # JAL RA, BACKEND_WRITE_BYTE ; write 0
    $backend_write_byte EF000000
    # ADDI A0, X0, 0 ; a0 = 0
    13050000
    # JAL RA, BACKEND_WRITE_BYTE ; write 0
    $backend_write_byte EF000000

:backend_PadToAlign_2
