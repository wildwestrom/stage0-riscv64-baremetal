    # SD A1, 16(SP) ; protect a1
    2338B100
    # ADDIW A0, X0, 513 ; scratch address
    1B051020
    # SLLI A0, A0, 0X16 ; scratch address
    13156501
    # ADDI A1, X0, 512 ; scratch size in bytes
    93050020

:backend_ClearScratch_loop
