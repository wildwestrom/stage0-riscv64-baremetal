; Bare metal M0 stage payload
; Style adapted to match conventions in `M0_riscv64.hex2` from [github.com/oriansj/stage0-posix-riscv64](https://github.com/oriansj/stage0-posix-riscv64/blob/master/M0_riscv64.hex2)
; Primary source: baremetal/GAS/M0.s and baremetal/GAS/M0_backend.s

; Register use:
; s1: heap pointer
; s2: input cursor
; s3: input end
; s4: struct HEAD
; s5: protected char
; s6: scratch

; Struct format: (size 32)
; NEXT => 0
; TYPE => 8
; TEXT => 16
; EXPRESSION => 24

; Types
; None => 0
; MACRO => 1
; STRING => 2

:_start
    # ADDIW SP, X0, 1029 ; Set up stack
    1B015040
    # SLLI SP, SP, 0X15 ; Set up stack
    13115101
    # ADDI S4, X0, 0 ; HEAD = NULL
    130A0000
    # ADDIW S1, X0, 1027 ; Heap starts here
    9B043040
    # SLLI S1, S1, 0X15 ; Heap starts here
    93945401
    # LUI S2, 0X1 ; Input buffer start
    37190000
    # ADDIW S2, S2, -2041 ; Input buffer start
    1B097980
    # SLLI S2, S2, 0X14 ; Input buffer start
    13194901
    # ADDI T1, S2, 0 ; Save start for later
    13030900

:read_input_loop
    # JAL RA, READ_UART ; Read a character from UART
    $read_uart EF000000
    # ADDI T0, X0, 4 ; Ctrl-D
    93024000
    # BEQ A0, T0, INPUT_DONE ; Done reading input
    @input_done 63005500
    # SB A0, 0(S2) ; Store byte in buffer
    2300A900
    # ADDI S2, S2, 1 ; Advance buffer pointer
    13091900
    # JAL X0, READ_INPUT_LOOP ; Jump unconditionally to read_input_loop
    $read_input_loop 6F000000

:input_done
    # ADDI S3, S2, 0 ; s3 = end of input buffer
    93090900
    # ADDI S2, T1, 0 ; s2 = start of input buffer
    13090300
    # ADDI A0, X0, 512 ; Allocate scratch
    13050020
    # JAL RA, MALLOC ; Get S pointer
    $malloc EF000000
    # ADDI S6, A0, 0 ; Save scratch pointer
    130B0500
    # JAL RA, TOKENIZE_LINE ; Get all lines
    $Tokenize_Line EF000000
    # ADDI A0, S4, 0 ; Prepare for Reverse_List
    13050A00
    # JAL RA, REVERSE_LIST ; Correct order
    $Reverse_List EF000000
    # ADDI S4, A0, 0 ; Update HEAD
    130A0500
    # JAL RA, IDENTIFY_MACROS ; Find the DEFINEs
    $Identify_Macros EF000000
    # JAL RA, LINE_MACRO ; Apply the DEFINEs
    $Line_Macro EF000000
    # JAL RA, PROCESS_STRING ; Handle strings
    $Process_String EF000000
    # JAL RA, EVAL_IMMEDIATES ; Handle numbers
    $Eval_Immediates EF000000
    # JAL RA, PRESERVE_OTHER ; Collect the remaining
    $Preserve_Other EF000000
    # JAL RA, SERIALIZE_EXPRESSIONS ; Build text stream for backend assembler
    $Serialize_Expressions EF000000
    # ADDI A2, S1, 0 ; Heap pointer for backend label allocations
    13860400
    # JAL RA, M0_BACKEND_ASSEMBLE_AND_EXEC ; Never returns on success
    $M0_backend_assemble_and_exec EF000000
    # JAL X0, FAIL ; Jump unconditionally to Fail
    $Fail 6F000000

:read_uart
    # LUI T0, 0X10000 ; UART_LSR
    B7020010
    # ADDIW T0, T0, 5 ; UART_LSR
    9B825200

:poll_rx
    # LB A0, 0(T0) ; Read LSR
    03850200
    # ANDI A0, A0, 1 ; Check bit 0 (Data Ready)
    13751500
    # BEQ A0, X0, POLL_RX ; If no data ready, keep polling
    @poll_rx 63000500
    # LUI T0, 0X10000 ; UART_BASE
    B7020010
    # LB A0, 0(T0) ; Read received byte
    03850200
    # JALR X0, 0(RA) ; return
    67800000

:Tokenize_Line
    # ADDI SP, SP, -8 ; allocate stack
    130181FF
    # SD RA, 0(SP) ; protect ra
    23301100

:restart
    # JAL RA, FGETC ; Read a char
    $fgetc EF000000
    # ADDI T0, X0, -4 ; EOF
    9302C0FF
    # BEQ A0, T0, DONE ; File is collected
    @done 63005500
    # ADDI A2, A0, 0 ; Protect C
    13060500
    # JAL RA, ISCOMMENTSTARTER ; Check for comments
    $IsCommentStarter EF000000
    # ADDI T0, X0, 1 ; If comment
    93021000
    # BEQ A0, T0, PURGE_LINECOMMENT ; try again
    @Purge_LineComment 63005500
    # ADDI A0, A2, 0 ; Put C in place for check
    13050600
    # JAL RA, ISTERMINATOR ; Check for terminators
    $IsTerminator EF000000
    # ADDI T0, X0, 1 ; If terminator
    93021000
    # BEQ A0, T0, RESTART ; try again
    @restart 63005500
    # ADDI A0, X0, 32 ; malloc struct P
    13050002
    # JAL RA, MALLOC ; Get pointer to P
    $malloc EF000000
    # ADDI A3, A0, 0 ; Protect P
    93060500
    # SD S4, 0(A3) ; P->NEXT = HEAD
    23B04601
    # SD X0, 8(A3) ; P->TYPE = None
    23B40600
    # SD X0, 16(A3) ; P->TEXT = NULL
    23B80600
    # SD X0, 24(A3) ; P->EXPRESSION = NULL
    23BC0600
    # ADDI S4, A3, 0 ; HEAD = P
    138A0600
    # ADDI A0, A2, 0 ; Put C in place for check
    13050600
    # JAL RA, ISSTRINGDELIMITER ; Check for string char
    $IsStringDelimiter EF000000
    # ADDI T0, X0, 1 ; If string char
    93021000
    # BEQ A0, T0, STORE_STRING ; Get string
    @Store_String 63005500
    # JAL RA, STORE_ATOM ; Get whole token
    $Store_Atom EF000000
    # JAL X0, RESTART ; Jump unconditionally to restart
    $restart 6F000000

:done
    # LD RA, 0(SP) ; restore ra
    83300100
    # ADDI SP, SP, 8 ; deallocate stack
    13018100
    # JALR X0, 0(RA) ; return
    67800000

:IsCommentStarter
    # ADDI T0, X0, 35 ; '#'
    93023002
    # BEQ A0, T0, ISCOMMENTSTARTER_TRUE ; Branch when condition is satisfied
    @IsCommentStarter_True 63005500
    # ADDI T0, X0, 59 ; ';'
    9302B003
    # BEQ A0, T0, ISCOMMENTSTARTER_TRUE ; Branch when condition is satisfied
    @IsCommentStarter_True 63005500
    # ADDI A0, X0, 0 ; Load immediate constant
    13050000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:IsCommentStarter_True
    # ADDI A0, X0, 1 ; Load immediate constant
    13051000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:IsTerminator
    # ADDI T0, X0, 10 ; '\n'
    9302A000
    # BEQ A0, T0, ISTERMINATOR_TRUE ; Branch when condition is satisfied
    @IsTerminator_True 63005500
    # ADDI T0, X0, 9 ; '\t'
    93029000
    # BEQ A0, T0, ISTERMINATOR_TRUE ; Branch when condition is satisfied
    @IsTerminator_True 63005500
    # ADDI T0, X0, 32 ; ' '
    93020002
    # BEQ A0, T0, ISTERMINATOR_TRUE ; Branch when condition is satisfied
    @IsTerminator_True 63005500
    # ADDI A0, X0, 0 ; Load immediate constant
    13050000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:IsTerminator_True
    # ADDI A0, X0, 1 ; Load immediate constant
    13051000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:IsStringDelimiter
    # ADDI T0, X0, 34 ; '"'
    93022002
    # BEQ A0, T0, ISSTRINGDELIMITER_TRUE ; Branch when condition is satisfied
    @IsStringDelimiter_True 63005500
    # ADDI T0, X0, 39 ; '\''
    93027002
    # BEQ A0, T0, ISSTRINGDELIMITER_TRUE ; Branch when condition is satisfied
    @IsStringDelimiter_True 63005500
    # ADDI A0, X0, 0 ; Load immediate constant
    13050000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:IsStringDelimiter_True
    # ADDI A0, X0, 1 ; Load immediate constant
    13051000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:Purge_LineComment
    # JAL RA, FGETC ; Get a char
    $fgetc EF000000
    # ADDI T0, X0, 10 ; While not LF
    9302A000
    # BNE A0, T0, PURGE_LINECOMMENT ; Keep reading
    @Purge_LineComment 63105500
    # JAL X0, RESTART ; Jump unconditionally to restart
    $restart 6F000000

:Store_String
    # ADDI SP, SP, -24 ; allocate stack
    130181FE
    # SD A1, 0(SP) ; protect a1
    2330B100
    # SD A2, 8(SP) ; protect a2
    2334C100
    # SD A3, 16(SP) ; protect a3
    2338D100
    # ADDI A0, X0, 2 ; Using TYPE STRING
    13052000
    # SD A0, 8(A3) ; HEAD->TYPE = STRING
    23B4A600
    # ADDI A1, A2, 0 ; Protect terminator
    93050600
    # ADDI A3, S6, 0 ; Protect string pointer
    93060B00

:Store_String_Loop
    # SB A2, 0(A3) ; write byte
    2380C600
    # JAL RA, FGETC ; read next char
    $fgetc EF000000
    # ADDI A2, A0, 0 ; Update C
    13060500
    # ADDI A3, A3, 1 ; STRING = STRING + 1
    93861600
    # BNE A1, A2, STORE_STRING_LOOP ; Keep looping unless we hit terminator
    @Store_String_Loop 6390C500
    # SB X0, 0(A3) ; terminate scratch string
    23800600
    # ADDI A0, S6, 0 ; Prepare the string in scratch
    13050B00
    # JAL RA, STRING_LENGTH ; Calculate length
    $string_length EF000000
    # ADDI A0, A0, 1 ; Add 1 for 0 terminator
    13051500
    # JAL RA, MALLOC ; Allocate memory
    $malloc EF000000
    # LD A3, 16(SP) ; restore a3 (HEAD)
    83360101
    # SD A0, 16(A3) ; HEAD->TEXT = STRING
    23B8A600
    # JAL RA, COPY_STRING ; Copy the string
    $copy_string EF000000
    # LD A1, 0(SP) ; restore a1
    83350100
    # LD A2, 8(SP) ; restore a2
    03368100
    # ADDI SP, SP, 24 ; deallocate stack
    13018101
    # JAL X0, RESTART ; Jump unconditionally to restart
    $restart 6F000000

:copy_string
    # ADDI SP, SP, -24 ; allocate stack
    130181FE
    # SD RA, 0(SP) ; protect ra
    23301100
    # SD A1, 8(SP) ; protect a1
    2334B100
    # SD A2, 16(SP) ; protect a2
    2338C100
    # ADDI A2, S6, 0 ; Get S
    13060B00

:copy_string_loop
    # LBU A1, 0(A2) ; S[0]
    83450600
    # BEQ A1, X0, COPY_STRING_DONE ; Check if we are done
    @copy_string_done 63800500
    # SB A1, 0(A0) ; Copy char
    2300B500
    # ADDI A2, A2, 1 ; S = S + 1
    13061600
    # ADDI A0, A0, 1 ; T = T + 1
    13051500
    # JAL X0, COPY_STRING_LOOP ; Keep going
    $copy_string_loop 6F000000

:copy_string_done
    # SB X0, 0(A0) ; write 0 terminator
    23000500
    # JAL RA, CLEARSCRATCH ; Clear scratch
    $ClearScratch EF000000
    # LD RA, 0(SP) ; restore ra
    83300100
    # LD A1, 8(SP) ; restore a1
    83358100
    # LD A2, 16(SP) ; restore a2
    03360101
    # ADDI SP, SP, 24 ; deallocate stack
    13018101
    # JALR X0, 0(RA) ; Return to caller
    67800000

:ClearScratch
    # ADDI SP, SP, -24 ; allocate stack
    130181FE
    # SD RA, 0(SP) ; protect ra
    23301100
    # SD A0, 8(SP) ; protect a0
    2334A100
    # SD A1, 16(SP) ; protect a1
    2338B100
    # ADDI A0, S6, 0 ; Prepare scratch
    13050B00
    # ADDI A1, X0, 512 ; scratch size in bytes
    93050020

:ClearScratch_loop
    # SB X0, 0(A0) ; Write zero: s[i] = 0
    23000500
    # ADDI A0, A0, 1 ; Increment: i = i + 1
    13051500
    # ADDI A1, A1, -1 ; remaining bytes--
    9385F5FF
    # BNE A1, X0, CLEARSCRATCH_LOOP ; Keep looping
    @ClearScratch_loop 63900500
    # LD RA, 0(SP) ; restore ra
    83300100
    # LD A0, 8(SP) ; restore a0
    03358100
    # LD A1, 16(SP) ; restore a1
    83350101
    # ADDI SP, SP, 24 ; deallocate stack
    13018101
    # JALR X0, 0(RA) ; return
    67800000

:Store_Atom
    # ADDI SP, SP, -24 ; allocate stack
    130181FE
    # SD RA, 0(SP) ; protect ra
    23301100
    # SD A2, 8(SP) ; protect a2
    2334C100
    # SD A3, 16(SP) ; protect a3
    2338D100
    # ADDI A3, S6, 0 ; Protect string pointer
    93060B00

:Store_Atom_loop
    # SB A2, 0(A3) ; write byte
    2380C600
    # JAL RA, FGETC ; read next char
    $fgetc EF000000
    # ADDI A2, A0, 0 ; Update C
    13060500
    # ADDI A3, A3, 1 ; STRING = STRING + 1
    93861600
    # JAL RA, ISTERMINATOR ; Check for terminators
    $IsTerminator EF000000
    # BEQ A0, X0, STORE_ATOM_LOOP ; Loop if not "\n\t "
    @Store_Atom_loop 63000500
    # SB X0, 0(A3) ; terminate scratch string
    23800600
    # ADDI A0, S6, 0 ; Prepare the string in scratch
    13050B00
    # JAL RA, STRING_LENGTH ; Calculate length
    $string_length EF000000
    # ADDI A0, A0, 1 ; Add 1 for 0 terminator
    13051500
    # JAL RA, MALLOC ; Allocate memory
    $malloc EF000000
    # LD A3, 16(SP) ; restore a3 (HEAD)
    83360101
    # SD A0, 16(A3) ; HEAD->TEXT = STRING
    23B8A600
    # JAL RA, COPY_STRING ; Copy the string
    $copy_string EF000000
    # ADDI A0, A3, 0 ; Return HEAD
    13850600
    # LD RA, 0(SP) ; restore ra
    83300100
    # LD A2, 8(SP) ; restore a2
    03368100
    # ADDI SP, SP, 24 ; deallocate stack
    13018101
    # JALR X0, 0(RA) ; return
    67800000

:Reverse_List
    # ADDI SP, SP, -16 ; allocate stack
    130101FF
    # SD A1, 0(SP) ; protect a1
    2330B100
    # SD A2, 8(SP) ; protect a2
    2334C100
    # ADDI A1, A0, 0 ; Set HEAD
    93050500
    # ADDI A0, X0, 0 ; ROOT = NULL
    13050000

:Reverse_List_Loop
    # BEQ A1, X0, REVERSE_LIST_DONE ; Stop if HEAD == NULL
    @Reverse_List_Done 63800500
    # LD A2, 0(A1) ; NEXT = HEAD->NEXT
    03B60500
    # SD A0, 0(A1) ; HEAD->NEXT = ROOT
    23B0A500
    # ADDI A0, A1, 0 ; ROOT = HEAD
    13850500
    # ADDI A1, A2, 0 ; HEAD = NEXT
    93050600
    # JAL X0, REVERSE_LIST_LOOP ; Continue looping
    $Reverse_List_Loop 6F000000

:Reverse_List_Done
    # LD A1, 0(SP) ; restore a1
    83350100
    # LD A2, 8(SP) ; restore a2
    03368100
    # ADDI SP, SP, 16 ; deallocate stack
    13010101
    # JALR X0, 0(RA) ; return
    67800000

:Identify_Macros
    # ADDI SP, SP, -24 ; allocate stack
    130181FE
    # SD RA, 0(SP) ; protect ra
    23301100
    # SD A0, 8(SP) ; protect a0
    2334A100
    # SD A2, 16(SP) ; protect a2
    2338C100
    # ADDI A2, A0, 0 ; I = HEAD
    13060500

:Identify_Macros_Loop
    # LD A0, 16(A2) ; I->TEXT
    03350601
    # JAL RA, MATCH_DEFINE ; IF "DEFINE" == I->TEXT
    $match_DEFINE EF000000
    # BNE A0, X0, IDENTIFY_MACROS_NEXT ; Check if we got macro
    @Identify_Macros_Next 63100500
    # ADDI A0, X0, 1 ; a0 = MACRO
    13051000
    # SD A0, 8(A2) ; I->TYPE = MACRO
    2334A600
    # LD A0, 0(A2) ; I->NEXT
    03350600
    # LD A0, 16(A0) ; I->NEXT->TEXT
    03350501
    # SD A0, 16(A2) ; I->TEXT = I->NEXT->TEXT
    2338A600
    # LD A0, 0(A2) ; I->NEXT
    03350600
    # LD A0, 0(A0) ; I->NEXT->NEXT
    03350500
    # LD A0, 16(A0) ; I->NEXT->NEXT->TEXT
    03350501
    # SD A0, 24(A2) ; I->EXPRESSION = I->NEXT->NEXT->TEXT
    233CA600
    # LD A0, 0(A2) ; I->NEXT
    03350600
    # LD A0, 0(A0) ; I->NEXT->NEXT
    03350500
    # LD A0, 0(A0) ; I->NEXT->NEXT->NEXT
    03350500
    # SD A0, 0(A2) ; I->NEXT = I->NEXT->NEXT->NEXT
    2330A600

:Identify_Macros_Next
    # LD A2, 0(A2) ; I = I->NEXT
    03360600
    # BNE A2, X0, IDENTIFY_MACROS_LOOP ; Check if we are done
    @Identify_Macros_Loop 63100600
    # LD RA, 0(SP) ; restore ra
    83300100
    # LD A0, 8(SP) ; restore a0
    03358100
    # LD A2, 16(SP) ; restore a2
    03360101
    # ADDI SP, SP, 24 ; deallocate stack
    13018101
    # JALR X0, 0(RA) ; return
    67800000

:match_DEFINE
    # LBU T0, 0(A0) ; Load value from memory
    83420500
    # ADDI T1, X0, 68 ; Load immediate constant
    13034004
    # BNE T0, T1, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63906200
    # LBU T0, 1(A0) ; Load value from memory
    83421500
    # ADDI T1, X0, 69 ; Load immediate constant
    13035004
    # BNE T0, T1, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63906200
    # LBU T0, 2(A0) ; Load value from memory
    83422500
    # ADDI T1, X0, 70 ; Load immediate constant
    13036004
    # BNE T0, T1, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63906200
    # LBU T0, 3(A0) ; Load value from memory
    83423500
    # ADDI T1, X0, 73 ; Load immediate constant
    13039004
    # BNE T0, T1, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63906200
    # LBU T0, 4(A0) ; Load value from memory
    83424500
    # ADDI T1, X0, 78 ; Load immediate constant
    1303E004
    # BNE T0, T1, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63906200
    # LBU T0, 5(A0) ; Load value from memory
    83425500
    # ADDI T1, X0, 69 ; Load immediate constant
    13035004
    # BNE T0, T1, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63906200
    # LBU T0, 6(A0) ; Load value from memory
    83426500
    # BNE T0, X0, MATCH_DEFINE_FALSE ; Branch when condition is satisfied
    @match_DEFINE_False 63900200
    # ADDI A0, X0, 0 ; Load immediate constant
    13050000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:match_DEFINE_False
    # ADDI A0, X0, 1 ; Load immediate constant
    13051000
    # JALR X0, 0(RA) ; Return to caller
    67800000

:match
    # ADDI SP, SP, -24 ; allocate stack
    130181FE
    # SD A1, 0(SP) ; protect a1
    2330B100
    # SD A2, 8(SP) ; protect a2
    2334C100
    # SD A3, 16(SP) ; protect a3
    2338D100
    # ADDI A2, A0, 0 ; S1 in place
    13060500
    # ADDI A3, A1, 0 ; S2 in place
    93860500

:match_Loop
    # LBU A0, 0(A2) ; S1[i]
    03450600
    # LBU A1, 0(A3) ; S2[i]
    83C50600
    # BNE A0, A1, MATCH_FALSE ; Check if they match
    @match_False 6310B500
    # ADDI A2, A2, 1 ; S1 = S1 + 1
    13061600
    # ADDI A3, A3, 1 ; S2 = S2 + 1
    93861600
    # BEQ A0, X0, MATCH_DONE ; Match if we reached end of string
    @match_Done 63000500
    # JAL X0, MATCH_LOOP ; Otherwise keep looping
    $match_Loop 6F000000

:match_False
    # ADDI A0, X0, 1 ; Return false
    13051000

:match_Done
    # LD A1, 0(SP) ; restore a1
    83350100
    # LD A2, 8(SP) ; restore a2
    03368100
    # LD A3, 16(SP) ; restore a3
    83360101
    # ADDI SP, SP, 24 ; deallocate stack
    13018101
    # JALR X0, 0(RA) ; return
    67800000

:Line_Macro
    # ADDI SP, SP, -32 ; allocate stack
    130101FE
    # SD RA, 0(SP) ; protect ra
    23301100
    # SD A0, 8(SP) ; protect a0
    2334A100
    # SD A1, 16(SP) ; protect a1
    2338B100
    # SD A2, 24(SP) ; protect a2
    233CC100

:Line_Macro_Loop
    # LD A1, 8(A0) ; I->TYPE
    83358500
    # ADDI T0, X0, 1 ; t0 = MACRO
    93021000
    # BNE A1, T0, LINE_MACRO_NEXT ; Move on unless I->TYPE == MACRO
    @Line_Macro_Next 63905500
    # LD A1, 16(A0) ; I->TEXT
    83350501
    # LD A2, 24(A0) ; I->EXPRESSION
    03368501
    # LD A0, 0(A0) ; I->NEXT
    03350500
    # JAL RA, SET_EXPRESSION ; Apply it
    $Set_Expression EF000000
    # JAL X0, LINE_MACRO_LOOP ; Move on to next
    $Line_Macro_Loop 6F000000

:Line_Macro_Next
    # LD A0, 0(A0) ; I->NEXT
    03350500
    # BNE A0, X0, LINE_MACRO_LOOP ; Check if we are done
    @Line_Macro_Loop 63100500
    # LD RA, 0(SP) ; restore ra
    83300100
    # LD A0, 8(SP) ; restore a0
    03358100
    # LD A1, 16(SP) ; restore a1
    83350101
    # LD A2, 24(SP) ; restore a2
    03368101
    # ADDI SP, SP, 32 ; deallocate stack
    13010102
    # JALR X0, 0(RA) ; return
    67800000

:Set_Expression
    # ADDI SP, SP, -40 ; allocate stack
    130181FD
