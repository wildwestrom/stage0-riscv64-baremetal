:backend_consume_token_done
    # SD X0, 0(A1) ; Pad with nulls
    23B00500
    # ADDI A1, A1, 8 ; Update the pointer
    93858500
    # LD RA, 0(SP) ; restore ra
    83300100
    # ADDI SP, SP, 8 ; Deallocate stack
